# 사용할 AI 모델: claude | openai | gemini | ollama
ACTIVE_MODEL=claude

# 임베딩 모델: openai | bge-m3 | ollama
# ※ 한번 정하면 바꾸지 말 것 (차원이 달라 테이블 재생성 + 전체 재인덱싱 필요)
# openai → 1536차원 (text-embedding-3-small)
# bge-m3 → 1024차원 (한국어 추천, ollama pull bge-m3 필요)
# ollama → 768차원  (nomic-embed-text)
EMBEDDING_MODEL=bge-m3

# Supabase
# SUPABASE_KEY는 service role 키 사용 (RLS 우회용, 절대 프론트에 노출 금지)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Supabase JWT Secret (Dashboard → Settings → API → Legacy JWT Secret)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
